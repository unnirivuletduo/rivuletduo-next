# Full WP REST endpoint base, for example:
# https://your-domain.com/wp-json/wp/v2
WORDPRESS_API_URL=

# Optional: custom post type slugs in WP REST API.
# Defaults are `services` and `work`.
WORDPRESS_SERVICES_TYPE=services
WORDPRESS_WORK_TYPE=work

# Optional public version if you also need client-side reads.
NEXT_PUBLIC_WORDPRESS_API_URL=

# Optional shared secret for secure contact submissions.
# Set the same value in your WordPress environment.
RIVULET_CONTACT_SECRET=
